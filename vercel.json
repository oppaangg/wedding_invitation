{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "^/css/(.*)$",
      "dest": "/css/$1"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/js/$1"
    },
    {
      "src": "^/photos/(.*)$",
      "dest": "/photos/$1"
    },
    {
      "src": "^/music/(.*)$",
      "dest": "/music/$1"
    },
    {
      "src": "^/favicon\\.ico$",
      "dest": "/favicon.ico"
    },
    {
      "src": "^(.*)$",
      "dest": "/api/index.php"
    }
  ]
}